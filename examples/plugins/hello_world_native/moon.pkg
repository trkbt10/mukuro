import {
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/core/json",
  "trkbt10/mukuro/interfaces",
  "trkbt10/mukuro/adapters/native" @native,
}

options(
  "is-main": true,
  link: { "native": { "cc-flags": "-lpthread -lsqlite3" } },
  targets: {
    "main.mbt": [ "native" ],
    "plugin.mbt": [ "native" ],
    "main_stub.mbt": [ "js", "wasm", "wasm-gc" ],
  },
)
