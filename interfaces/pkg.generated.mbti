}

pub(open) trait DynamicPluginManager {
  scan_plugins(Self) -> Array[String] raise
  add_plugin(Self, manifest_path~ : String) -> Unit raise
  async remove_plugin(Self, id~ : String) -> Unit
  async enable_plugin(Self, id~ : String) -> Unit
  async disable_plugin(Self, id~ : String) -> Unit
  async reload_plugin(Self, id~ : String) -> Unit
  get_plugin_state(Self, id~ : String) -> PluginState raise
  list_plugin_states(Self) -> Array[PluginState]
  start_watching(Self) -> Unit raise
  stop_watching(Self) -> Unit
}

pub(open) trait DynamicToolManager {
  scan_tools(Self) -> Array[String] raise ToolManagerError
  load_tool(Self, manifest_path~ : String) -> ToolState raise ToolManagerError
  enable_tool(Self, id~ : String) -> Unit raise ToolManagerError
  disable_tool(Self, id~ : String) -> Unit raise ToolManagerError
  remove_tool(Self, id~ : String) -> Unit raise ToolManagerError
  reload_tool(Self, id~ : String) -> Unit raise ToolManagerError
  get_tool_state(Self, id~ : String) -> ToolState?
  list_tool_states(Self) -> Array[ToolState]
  list_enabled_definitions(Self) -> Array[@types.ToolDefinition]
  has_tool(Self, id~ : String) -> Bool
}

pub(open) trait EmbeddingProvider {
  embed(Self, String) -> Array[Double] raise EmbeddingError
  embed_batch(Self, Array[String]) -> Array[Array[Double]] raise EmbeddingError
  dimension(Self) -> Int
}

pub(open) trait Environment {
  get_env(Self, name~ : String) -> String?
  set_env(Self, name~ : String, value~ : String) -> Unit raise
  unset_env(Self, name~ : String) -> Unit raise
  get_all_env(Self) -> Map[String, String]
}

pub(open) trait FileStore {
  read_file(Self, path~ : String) -> Bytes raise
  write_file(Self, path~ : String, data~ : Bytes) -> Unit raise
  exists(Self, path~ : String) -> Bool raise
