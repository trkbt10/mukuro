// Traits
pub(open) trait Authenticator {
  validate(Self, token~ : String) -> AuthResult
  issue_token(Self, user_id~ : String) -> String raise AuthError
  revoke(Self, token~ : String) -> Unit raise AuthError
}

pub(open) trait ChannelAdapter {
  name(Self) -> String
  async connect(Self) -> Unit
  async disconnect(Self) -> Unit
  is_connected(Self) -> Bool
  async send(Self, @types.OutboundMessage) -> Unit
  async receive(Self) -> @types.InboundEnvelope
}

pub(open) trait ChannelManager {
  register(Self, &ChannelAdapter) -> Unit
  unregister(Self, String) -> Unit
  get_channel(Self, String) -> &ChannelAdapter?
  list_channels(Self) -> Array[String]
  async connect_all(Self) -> Unit
  async disconnect_all(Self) -> Unit
}

pub(open) trait Clock {
  now_ms(Self) -> Int64
  now_seconds(Self) -> Int64
}

pub(open) trait ConfigLoader {
  load(Self, path~ : String) -> @types.MukuroConfig raise ConfigError
  load_with_env(Self, path~ : String, env~ : &Environment) -> @types.MukuroConfig raise ConfigError
  load_from_env(Self, env~ : &Environment) -> @types.MukuroConfig raise ConfigError
  default_config(Self) -> @types.MukuroConfig
}

pub(open) trait ConfigValidator {
  validate(Self, config~ : @types.MukuroConfig) -> Unit raise ConfigError
}

pub(open) trait ConfigWriter {
  write_atomic(Self, config~ : @types.MukuroConfig) -> Unit raise ConfigError
  serialize(Self, config~ : @types.MukuroConfig) -> String raise ConfigError
}

pub(open) trait ConnectablePlugin {
