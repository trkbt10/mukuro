pub(all) enum ToolSource {
  Plugin(String)
  UserDefined
  MCP(String)
}
pub fn ToolSource::is_builtin(Self) -> Bool

pub(all) struct ToolState {
  id : String
  name : String
  source : ToolSource
  enabled : Bool
  status : ToolStatus
  loaded_at : Int64
  description : String
  parameters : Json
  settings_schema : Json?
}
pub fn ToolState::builtin(id~ : String, name~ : String, description~ : String, parameters~ : Json, settings_schema? : Json?) -> Self
pub fn ToolState::from_mcp(server_id~ : String, tool_name~ : String, description~ : String, parameters~ : Json, settings_schema? : Json?) -> Self
pub fn ToolState::from_plugin(plugin_id~ : String, capability~ : String, description~ : String, parameters~ : Json, settings_schema? : Json?) -> Self
pub fn ToolState::user_defined(id~ : String, name~ : String, description~ : String, parameters~ : Json, settings_schema? : Json?) -> Self

pub(all) enum ToolStatus {
  Available
  Disabled
  Error(String)
  Unavailable
}

pub(all) struct TransportConfig {
  timeout_ms : Int
  request_timeout_ms : Int
  auto_reconnect : Bool
  max_reconnect_attempts : Int
  reconnect_base_delay_ms : Int
  reconnect_max_delay_ms : Int
}
pub fn TransportConfig::default() -> Self

pub(all) enum TransportState {
  Disconnected
  Connecting
  Connected
  Reconnecting
  Stopped
  Error(String)
}

pub(all) struct UnifiedMessage {
  id : String
  chat_id : String
  sender_id : String
  sender_name : String
  content : String
  timestamp : Int64
  reply_to : String?
  metadata : Map[String, Json]
}
pub fn UnifiedMessage::new(id~ : String, chat_id~ : String, sender_id~ : String, sender_name~ : String, content~ : String, timestamp~ : Int64) -> Self
pub fn UnifiedMessage::to_json(Self) -> Json
pub fn UnifiedMessage::with_reply(id~ : String, chat_id~ : String, sender_id~ : String, sender_name~ : String, content~ : String, timestamp~ : Int64, reply_to~ : String) -> Self

pub(all) enum WsMessage {
  Text(String)
  Binary(Bytes)
  Close(code~ : Int, reason~ : String)
  Ping(Bytes)
  Pong(Bytes)
}

