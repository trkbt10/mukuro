{
  "name": "@mukuro/dashboard",
  "version": "0.1.0",
  "description": "Web dashboard for mukuro agent framework",
  "type": "module",
  "bin": {
    "mukuro-dashboard": "./bin/cli.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node bin/cli.js",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@mukuro/client": "*",
    "@tanstack/react-query": "^5.90.21",
    "http-proxy-middleware": "^3.0.5",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-editor-ui": "^0.1.1",
    "react-panel-layout": "^0.7.1",
    "react-router-dom": "^7.13.1",
    "react-use": "^17.6.0",
    "sirv": "^3.0.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "happy-dom": "^20.7.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "mukuro",
    "dashboard",
    "agent",
    "ai"
  ],
  "license": "Apache-2.0"
}
