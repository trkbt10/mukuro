import {
  "trkbt10/mukuro/cmd/cli" @cli,
  "trkbt10/mukuro/cmd/config" @cmd_config,
  "trkbt10/mukuro/core/config" @config,
  "trkbt10/mukuro/core/control" @control,
  "trkbt10/mukuro/interfaces",
  "trkbt10/mukuro/adapters/native" @native,
  "trkbt10/mukuro/lib/bytes" @bytes,
