import {
  "moonbitlang/core/env",
  "moonbitlang/core/json",
  "trkbt10/mukuro/interfaces",
  "trkbt10/mukuro/core/agent" @agent,
  "trkbt10/mukuro/core/context" @context,
  "trkbt10/mukuro/core/session" @session,
  "trkbt10/mukuro/core/tool" @tool,
  "trkbt10/mukuro/core/types" @types,
}

options(
  "warn-list": "-29",
  "is-main": true,
  targets: {
    "main.mbt": [ "native" ],
    "main_js.mbt": [ "js" ],
    "main_wasm.mbt": [ "wasm", "wasm-gc" ],
  },
)
