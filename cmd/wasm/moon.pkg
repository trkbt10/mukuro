import {
  "trkbt10/mukuro/adapters/js" @js,
  "trkbt10/mukuro/core/types" @types,
  "trkbt10/mukuro/tools/builtin" @builtin,
  "moonbitlang/core/json",
}

options(
  "is-main": true,
  targets: {
    "main.mbt": [ "js" ],
    "main_native.mbt": [ "native" ],
    "main_wasm.mbt": [ "wasm", "wasm-gc" ],
  },
)
